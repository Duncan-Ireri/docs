{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "UrbnBox",
  "colors": {
    "primary": "#111827",
    "light": "#16A34A",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "guides/integration-options",
              "quickstart"
            ]
          },
          {
            "group": "Integration guides",
            "pages": [
              "guides/checkout-widget",
              "guides/shopify",
              "guides/woocommerce"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/partners-and-vendors",
              "concepts/authentication"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "brackets-curly",
        "openapi": "openapi.json",
        "pages": [
          "reference-overview",
          {
            "group": "Partner API",
            "pages": [
              "POST /api/partner/v1/shipment-quote",
              "POST /api/partner/v1/shipments",
              "GET /api/partner/v1/shipments/{id}",
              "GET /api/partner/v1/locker-availability",
              "POST /api/partner/v1/checkout-sessions",
              "GET /api/partner/v1/checkout-sessions/{id}",
              "POST /api/partner/v1/checkout-sessions/{id}/cancel"
            ]
          },
          {
            "group": "Public booking API",
            "pages": [
              "GET /api/public/stores",
              "GET /api/public/stores/nearby",
              "GET /api/public/locker-bookings/options",
              "POST /api/public/locker-bookings"
            ]
          },
          {
            "group": "Shopify callbacks",
            "pages": [
              "POST /integrations/shopify/carrier-rates",
              "POST /integrations/shopify/fulfillment"
            ]
          },
          {
            "group": "Vendor API",
            "pages": [
              "api-reference/vendor/orders",
              "api-reference/vendor/shipments",
              "api-reference/vendor/webhooks",
              "GET /api/vendor/v1/orders",
              "POST /api/vendor/v1/orders",
              "GET /api/vendor/v1/orders/csv-template",
              "POST /api/vendor/v1/orders/import-csv",
              "GET /api/vendor/v1/shipments",
              "POST /api/vendor/v1/shipments",
              "GET /api/vendor/v1/shipments/csv-template",
              "POST /api/vendor/v1/shipments/import-csv",
              "GET /api/vendor/v1/webhooks",
              "POST /api/vendor/v1/webhooks",
              "DELETE /api/vendor/v1/webhooks/{id}",
              "GET /api/vendor/v1/earnings",
              "POST /api/vendor/v1/shipment-quote"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "UrbnBox",
          "href": "https://portal.urbnbox.io",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/icon.png",
    "dark": "/logo/icon.png"
  },
  "navbar": {
    "links": [
      {
        "label": "API quickstart",
        "href": "/quickstart"
      }
    ],
    "primary": {
      "type": "button",
      "label": "UrbnBox app",
      "href": "https://portal.urbnbox.io"
    }
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "interactive",
      "proxy": false
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
